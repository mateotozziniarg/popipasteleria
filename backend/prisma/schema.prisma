generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Evento {
  id          Int         @id @default(autoincrement())
  nombre      String
  fecha       DateTime
  descripcion String?
  createdAt   DateTime    @default(now())
  pedidos     Pedido[]
  gastos      Gasto[]
  propuestas  Propuesta[]
}

model MateriaPrima {
  id            Int      @id @default(autoincrement())
  nombre        String
  descripcion   String?
  precioDefault Decimal  @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  gastos        Gasto[]
}

model Gasto {
  id             Int           @id @default(autoincrement())
  fecha          DateTime
  eventoId       Int?
  evento         Evento?       @relation(fields: [eventoId], references: [id])
  materiaPrimaId Int?
  materiaPrima   MateriaPrima? @relation(fields: [materiaPrimaId], references: [id])
  cantidad       Decimal?      @db.Decimal(10, 2)
  precioUnitario Decimal?      @db.Decimal(10, 2)
  monto          Decimal       @db.Decimal(10, 2)
  descripcion    String?
  notas          String?
  createdAt      DateTime      @default(now())
}

model Cliente {
  id        Int            @id @default(autoincrement())
  nombre    String
  telefono  String?
  direccion String?
  notas     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  pedidos   Pedido[]
  menciones TareaMencion[]
}

model Pedido {
  id               Int               @id @default(autoincrement())
  eventoId         Int?
  evento           Evento?           @relation(fields: [eventoId], references: [id])
  clienteId        Int?
  cliente          Cliente?          @relation(fields: [clienteId], references: [id])
  nombreCliente    String
  telefono         String?
  descripcion      String?
  precioTotal      Decimal           @db.Decimal(10, 2)
  estadoEntrega    EstadoEntrega     @default(pendiente)
  estadoPago       EstadoPago        @default(sin_seña)
  notas            String?
  montoSeña        Decimal?          @db.Decimal(10, 2)
  fechaEntrega     DateTime?
  modalidadEntrega ModalidadEntrega?
  createdAt        DateTime          @default(now())
  productos        PedidoProducto[]
  menciones        TareaMencion[]
}

model Producto {
  id            Int              @id @default(autoincrement())
  nombre        String
  descripcion   String?
  precioDefault Decimal          @db.Decimal(10, 2)
  createdAt     DateTime         @default(now())
  pedidos       PedidoProducto[]
}

model PedidoProducto {
  id             Int      @id @default(autoincrement())
  pedidoId       Int
  pedido         Pedido   @relation(fields: [pedidoId], references: [id])
  productoId     Int
  producto       Producto @relation(fields: [productoId], references: [id])
  cantidad       Int
  precioUnitario Decimal  @db.Decimal(10, 2)
}

model Tarea {
  id         Int            @id @default(autoincrement())
  texto      String
  fecha      DateTime
  completada Boolean        @default(false)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  menciones  TareaMencion[]
}

model TareaMencion {
  id             Int         @id @default(autoincrement())
  tareaId        Int
  tarea          Tarea       @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  tipo           TipoMencion
  clienteId      Int?
  cliente        Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  pedidoId       Int?
  pedido         Pedido?     @relation(fields: [pedidoId], references: [id], onDelete: SetNull)
  posicionInicio Int
  posicionFin    Int
}

enum EstadoEntrega {
  pendiente
  entregado
}

enum EstadoPago {
  sin_seña
  señado
  pagado
}

enum ModalidadEntrega {
  ENVIO
  RETIRA
}

enum TipoMencion {
  CLIENTE
  PEDIDO
}

model Usuario {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  nombre       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum EstadoPropuesta {
  BORRADOR
  PRESENTADA
  CONFIRMADA
}

enum CategoriaIdea {
  RELLENO
  DECORACION
  PACKAGING
  PRECIO
  OTRO
}

model Propuesta {
  id          Int                 @id @default(autoincrement())
  nombre      String
  tematica    String?
  descripcion String?
  estado      EstadoPropuesta     @default(BORRADOR)
  eventoId    Int?
  evento      Evento?             @relation(fields: [eventoId], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  productos   PropuestaProducto[]
  combos      PropuestaCombo[]
  ideas       PropuestaIdea[]
}

model PropuestaProducto {
  id          Int                      @id @default(autoincrement())
  propuestaId Int
  propuesta   Propuesta                @relation(fields: [propuestaId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  precio      Decimal?                 @db.Decimal(10, 2)
  notas       String?
  combos      PropuestaComboProducto[]
}

model PropuestaCombo {
  id          Int                      @id @default(autoincrement())
  propuestaId Int
  propuesta   Propuesta                @relation(fields: [propuestaId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  precioCombo Decimal?                 @db.Decimal(10, 2)
  productos   PropuestaComboProducto[]
}

model PropuestaComboProducto {
  id                  Int               @id @default(autoincrement())
  comboId             Int
  combo               PropuestaCombo    @relation(fields: [comboId], references: [id], onDelete: Cascade)
  propuestaProductoId Int
  producto            PropuestaProducto @relation(fields: [propuestaProductoId], references: [id], onDelete: Cascade)
  cantidad            Int               @default(1)
}

model PropuestaIdea {
  id          Int           @id @default(autoincrement())
  propuestaId Int
  propuesta   Propuesta     @relation(fields: [propuestaId], references: [id], onDelete: Cascade)
  texto       String
  categoria   CategoriaIdea
}
